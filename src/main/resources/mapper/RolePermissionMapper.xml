<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhkj.xsys.mapper.RolePermissionMapper">

    <delete id="deleteByRoleId">
        DELETE FROM sys_role_permission WHERE role_id = #{roleId}
    </delete>

    <delete id="deleteByPermissionId">
        DELETE FROM sys_role_permission WHERE permission_id = #{permissionId}
    </delete>

    <insert id="insert">
        INSERT INTO sys_role_permission (role_id, permission_id) VALUES (#{roleId}, #{permissionId})
    </insert>

    <select id="findPermissionIdsByRoleId" resultType="long">
        SELECT permission_id FROM sys_role_permission WHERE role_id = #{roleId}
    </select>
</mapper>
