<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhkj.xsys.mapper.MenuRoleMapper">

    <select id="findRoleIdsByMenuId" resultType="java.lang.Long">
        SELECT role_id FROM sys_menu_role WHERE menu_id = #{menuId}
    </select>

    <delete id="deleteByMenuId">
        DELETE FROM sys_menu_role WHERE menu_id = #{menuId}
    </delete>

    <insert id="insert">
        INSERT INTO sys_menu_role (menu_id, role_id) VALUES (#{menuId}, #{roleId})
    </insert>

    <insert id="batchInsert">
        INSERT INTO sys_menu_role (menu_id, role_id) VALUES
        <foreach collection="roleIds" item="roleId" separator=",">
            (#{menuId}, #{roleId})
        </foreach>
    </insert>

</mapper>
