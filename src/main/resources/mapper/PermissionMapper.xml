<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.zhkj.xsys.mapper.PermissionMapper">

    <resultMap id="PermResult" type="cn.zhkj.xsys.domain.Permission">
        <id property="id" column="id"/>
        <result property="code" column="code"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
    </resultMap>

    <select id="findById" resultMap="PermResult">
        SELECT * FROM sys_permission WHERE id = #{id}
    </select>

    <select id="findByCode" resultMap="PermResult">
        SELECT * FROM sys_permission WHERE code = #{code}
    </select>

    <select id="findAll" resultMap="PermResult">
        SELECT * FROM sys_permission ORDER BY id ASC
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM sys_permission
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_permission (code, name, description)
        VALUES (#{code}, #{name}, #{description})
    </insert>

    <update id="update">
        UPDATE sys_permission
        SET code = #{code},
            name = #{name},
            description = #{description}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_permission WHERE id = #{id}
    </delete>
</mapper>
